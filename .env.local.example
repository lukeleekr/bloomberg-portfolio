# Supabase — get these from https://app.supabase.com -> your project -> Settings -> API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # the service_role key, not the anon key. Server-only. Never expose to the browser.

# Admin auth for guestbook moderation
# Generate a strong random password and a 32+ char random secret:
#   openssl rand -base64 32   (for ADMIN_PASSWORD)
#   openssl rand -hex 32      (for ADMIN_SESSION_SECRET)
ADMIN_PASSWORD=replace-me-with-strong-password
ADMIN_SESSION_SECRET=replace-me-with-32-plus-char-random-hex
